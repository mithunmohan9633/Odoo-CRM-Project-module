<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ===================== ACTIONS ===================== -->

    <!-- Kanban Action: Projects grouped by stage -->
    <record id="action_construction_project_kanban" model="ir.actions.act_window">
        <field name="name">Construction Projects</field>
        <field name="res_model">project.project</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="context">{'default_active': True}</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                No construction projects yet!
            </p>
            <p>
                Projects are created automatically when a CRM deal is marked as Won.
                You can also create one manually here.
            </p>
        </field>
    </record>

    <!-- ===================== KANBAN VIEW ===================== -->

    <record id="view_construction_project_kanban" model="ir.ui.view">
        <field name="name">construction.project.kanban</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <kanban default_group_by="last_update_status" class="o_kanban_project_cards">
                <field name="name"/>
                <field name="partner_id"/>
                <field name="last_update_status"/>
                <field name="date_start"/>
                <field name="date"/>
                <field name="user_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <!-- Header: Project Name -->
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top mb-2">
                                    <div class="o_kanban_record_headings">
                                        <strong class="o_kanban_record_title">
                                            <field name="name"/>
                                        </strong>
                                    </div>
                                </div>

                                <!-- Client -->
                                <div t-if="record.partner_id.value" class="o_kanban_record_subtitle text-muted mb-1">
                                    <i class="fa fa-building-o me-1"/>
                                    <field name="partner_id"/>
                                </div>

                                <!-- Date Range -->
                                <div class="o_kanban_record_bottom mt-2">
                                    <div class="oe_kanban_bottom_left text-muted small">
                                        <t t-if="record.date_start.value">
                                            <i class="fa fa-calendar me-1"/>
                                            <span>
                                                <field name="date_start"/> – <field name="date"/>
                                            </span>
                                        </t>
                                    </div>
                                    <div class="oe_kanban_bottom_right">
                                        <field name="user_id" widget="many2one_avatar_user"/>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ===================== LIST VIEW ===================== -->

    <record id="view_construction_project_list" model="ir.ui.view">
        <field name="name">construction.project.list</field>
        <field name="model">project.project</field>
        <field name="arch" type="xml">
            <list string="Construction Projects" decoration-info="last_update_status == 'on_track'"
                  decoration-warning="last_update_status == 'at_risk'"
                  decoration-danger="last_update_status == 'off_track'">
                <field name="name" string="Project Name"/>
                <field name="partner_id" string="Client"/>
                <field name="user_id" widget="many2one_avatar_user" string="Project Manager"/>
                <field name="date_start" string="Start Date"/>
                <field name="date" string="End Date"/>
                <field name="last_update_status" string="Status" widget="badge"
                       decoration-info="last_update_status == 'on_track'"
                       decoration-warning="last_update_status == 'at_risk'"
                       decoration-danger="last_update_status == 'off_track'"/>
            </list>
        </field>
    </record>

    <!-- ===================== MENUS ===================== -->

    <!-- Root menu -->
    <menuitem
        id="menu_construction_root"
        name="Construction"
        sequence="10"
        web_icon="construction_workflow,static/description/icon.png"
    />

    <!-- Sub-menu: Projects pipeline -->
    <menuitem
        id="menu_construction_projects"
        name="Projects"
        parent="menu_construction_root"
        action="action_construction_project_kanban"
        sequence="10"
    />


    <!-- ===================== TASK STAGE FORM (hide clutter) ===================== -->

    <!-- Hide Email Template + Sequence + SMS Template from stage form -->
    <record id="view_project_task_type_form_construction" model="ir.ui.view">
        <field name="name">project.task.type.form.construction</field>
        <field name="model">project.task.type</field>
        <field name="inherit_id" ref="project.task_type_edit"/>
        <field name="arch" type="xml">
            <!-- Hide Email Template -->
            <xpath expr="//field[@name='mail_template_id']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
            <!-- Hide Sequence -->
            <xpath expr="//field[@name='sequence']" position="attributes">
                <attribute name="invisible">1</attribute>
            </xpath>
        </field>
    </record>


</odoo>

